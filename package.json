{
	"name": "toby",
	"version": "0.3.0",
	"description": "CLI-based tool for managing your life — email, calendar, todos, and more",
	"type": "module",
	"bin": {
		"toby": "./dist/cli.js"
	},
	"scripts": {
		"postinstall": "bunx patch-package && bun ./scripts/install-git-hooks.mjs",
		"build": "tsup",
		"build:executable": "bun build ./src/cli.ts --compile --outfile ./dist/toby",
		"dev": "tsx src/cli.ts",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check . --write",
		"format": "bunx biome format . --write",
		"test": "bunx vitest run",
		"test:watch": "bunx vitest",
		"release": "release-it",
		"release:dry": "release-it --dry-run",
		"release:ci": "bun ./scripts/release-ci.mjs"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.53",
		"ai": "^6.0.168",
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"googleapis": "^140.0.0",
		"ink": "^7.0.1",
		"ink-multiline-input": "^0.1.0",
		"open": "^10.1.0",
		"react": "^19.2.0",
		"react-devtools-core": "^7.0.1",
		"zod": "3"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.2",
		"lint-staged": "^16.4.0",
		"patch-package": "^8.0.1",
		"release-it": "^20.0.1",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,jsonc,md,yml,yaml}": ["bunx biome check --write"],
		"*.{js,jsx,ts,tsx}": ["bunx biome check --write"]
	}
}
